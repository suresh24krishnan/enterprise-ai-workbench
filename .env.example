# =============================================================================
# Enterprise AI Workbench — Environment Configuration
# Copy this file to .env and fill in values for your environment.
# Never commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# Values: local | sandbox | production
# -----------------------------------------------------------------------------
ENVIRONMENT=local

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
BACKEND_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Database
# Phase 1: SQLite (file path)
# Phase 2+: Replace with PostgreSQL connection string
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./workbench.db
# DATABASE_URL=postgresql://user:password@host:5432/workbench

# -----------------------------------------------------------------------------
# Identity Provider
# Phase 1: mock (accepts any credentials)
# Phase 2+: azure_ad | okta
# -----------------------------------------------------------------------------
IDENTITY_PROVIDER=mock
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# OKTA_DOMAIN=
# OKTA_CLIENT_ID=
# OKTA_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# ClaimCenter Adapter
# Phase 1: mock
# Phase 2+: sandbox | production
# -----------------------------------------------------------------------------
CLAIMCENTER_ADAPTER=mock
# CLAIMCENTER_BASE_URL=
# CLAIMCENTER_API_KEY=

# -----------------------------------------------------------------------------
# Model Provider
# Phase 1: mock
# Phase 2+: anthropic | azure_openai | enterprise_gateway
# -----------------------------------------------------------------------------
MODEL_PROVIDER=mock
# ANTHROPIC_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# ENTERPRISE_MODEL_GATEWAY_URL=

# -----------------------------------------------------------------------------
# Model Router
# Controls which models handle which task types
# -----------------------------------------------------------------------------
MODEL_ROUTER_DEFAULT_MODEL=mock-standard
MODEL_ROUTER_HIGH_RISK_MODEL=mock-premium
MODEL_ROUTER_COST_THRESHOLD=0.10

# -----------------------------------------------------------------------------
# Governance
# -----------------------------------------------------------------------------
GOVERNANCE_STRICT_MODE=true
GOVERNANCE_POLICY_PATH=shared/policies

# -----------------------------------------------------------------------------
# Audit Store
# Phase 1: local SQLite
# Phase 2+: enterprise_audit_platform
# -----------------------------------------------------------------------------
AUDIT_STORE=sqlite
# AUDIT_STORE=splunk
# AUDIT_STORE=elastic
# SPLUNK_HEC_URL=
# SPLUNK_HEC_TOKEN=

# -----------------------------------------------------------------------------
# RAG / Knowledge Provider
# Phase 1: local file-based
# Phase 2+: enterprise_vector_db
# -----------------------------------------------------------------------------
KNOWLEDGE_PROVIDER=local
# KNOWLEDGE_PROVIDER=pinecone
# KNOWLEDGE_PROVIDER=azure_ai_search
# PINECONE_API_KEY=
# PINECONE_INDEX=

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET_KEY=replace-this-with-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
